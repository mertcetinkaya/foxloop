PORT=8001

# Cursor SDK
CURSOR_API_KEY=

# Firestore (VM service account or GOOGLE_APPLICATION_CREDENTIALS path)
GOOGLE_CLOUD_PROJECT=

# GitHub publish (fine-grained PAT or deploy key)
GITHUB_TOKEN=
GITHUB_REPO=mertcetinkaya/foxloop
GITHUB_BRANCH=main

# Path to web app root on VM (for publish materialize + git)
FOXLOOP_WEB_ROOT=/path/to/foxloop/forge web/foxloop

# CORS — Netlify / local dev origins
CORS_ORIGINS=http://localhost:3000,https://foxloop.ai

PORT=8001

# Cursor SDK
CURSOR_API_KEY=
# Model id from Cursor.models.list() — NOT the UI variant slug
CURSOR_MODEL=claude-opus-4-8
# Opus 4.8: thinking=true + effort=high (set false for base Opus without thinking)
# CURSOR_OPUS_THINKING_HIGH=false
# Or override params entirely:
# CURSOR_MODEL_PARAMS=[{"id":"thinking","value":"true"},{"id":"effort","value":"high"},{"id":"context","value":"300k"},{"id":"fast","value":"false"}]

# OpenAI — optional fallback cover generation for legacy drafts without upload
OPENAI_API_KEY=
# OPENAI_IMAGE_MODEL=gpt-image-1

# Shared database (required for Save/Publish — same project on Mac + VM)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# Local Mac: path to service account JSON, or run `gcloud auth application-default login`
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# GitHub — not used for save (games live in Firestore)
# GITHUB_TOKEN=

CORS_ORIGINS=http://localhost:3000,https://foxloop.ai

# Optional paths (defaults work when repo layout is standard)
# FOXLOOP_WEB_ROOT=/path/to/foxloop/forge web/foxloop
# REPO_ROOT=/path/to/foxloop

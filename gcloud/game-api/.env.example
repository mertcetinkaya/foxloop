PORT=8001

# Cursor SDK
CURSOR_API_KEY=
# Model id from Cursor.models.list() — NOT the UI variant slug
CURSOR_MODEL=composer-2.5
# Composer 2.5: fast=true is applied automatically when CURSOR_MODEL=composer-2.5
# Or override params entirely:
# CURSOR_MODEL_PARAMS=[{"id":"fast","value":"true"}]

# --- AI cover art (optional) ---
# Set OPENAI_API_KEY to generate AI covers in parallel with the game build.
# Leave empty or comment out the line — no OpenAI calls; simple canvas cover instead.
# OPENAI_API_KEY=sk-...
# Cheapest defaults (used when key is set):
# OPENAI_IMAGE_MODEL=gpt-image-1-mini
# OPENAI_IMAGE_QUALITY=low
# OPENAI_IMAGE_SIZE=1024x1024

# Shared database (required for Save/Publish — same project on Mac + VM)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# Local Mac: path to service account JSON, or run `gcloud auth application-default login`
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# GitHub — not used for save (games live in Firestore)
# GITHUB_TOKEN=

CORS_ORIGINS=http://localhost:3000,https://foxloop.ai

# Optional: skip loginEvents when running game-api locally on Mac (SKIP_LOGIN_EVENTS=true).
# VM also skips loginEvents for requests from http://localhost:3000 (no env needed on VM).
# SKIP_LOGIN_EVENTS=true

# Optional paths (defaults work when repo layout is standard)
# FOXLOOP_WEB_ROOT=/path/to/foxloop/forge web/foxloop
# REPO_ROOT=/path/to/foxloop
